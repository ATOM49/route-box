{
  "name": "route-box",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "sharp"
    ]
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @app/web --filter @app/api --filter @app/worker dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @repo/db prisma generate",
    "db:migrate": "pnpm --filter @repo/db prisma migrate dev",
    "db:deploy": "pnpm --filter @repo/db prisma migrate deploy",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down -v"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.5.3",
    "typescript": "catalog:",
    "typescript-eslint": "^8.31.0"
  }
}
